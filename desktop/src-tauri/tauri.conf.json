{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Familybook",
  "version": "0.1.0",
  "identifier": "com.familybook.desktop",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "title": "Familybook",
        "width": 1600,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Familybook local genealogy desktop app",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/familybook-backend"
    ]
  }
}
